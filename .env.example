# probable-intel environment configuration
# Copy to .env and fill in values — never commit .env

# LLM
ANTHROPIC_API_KEY=

# Storage
DATA_DIR=/data/probable-intel
SQLITE_PATH=/data/probable-intel/main.db

# Alert sinks
ALERT_WEBHOOK_URL=
ALERT_SMTP_HOST=
ALERT_SMTP_PORT=587
ALERT_SMTP_FROM=

# Outbound proxy — all harvester nodes (FeedNode, ApiNode, SocialNode, ReconNode, WebNode)
# honour these standard env vars via httpx trust_env=True.
# Use any of: http://, https://, socks5://, socks5h:// (socks5h resolves DNS via proxy)
#
# Examples:
#   SSH SOCKS tunnel:          ssh -D 1080 user@residential-box
#     HTTPS_PROXY=socks5h://localhost:1080
#   Residential proxy service: HTTPS_PROXY=http://user:pass@proxy.example.com:8080
#   torsocks (Tor):            torify pi run ...   (no env var needed)
HTTPS_PROXY=
HTTP_PROXY=
ALL_PROXY=

# Proxy pool (FingerprintDefenseNode managed pool — separate from above)
PROXY_POOL_ENDPOINT=
PROXY_POOL_TOKEN=

# Encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
MASTER_KEY=

# Hub
HUB_BIND_HOST=127.0.0.1
HUB_LOG_LEVEL=INFO

# S3 archive (optional)
S3_BUCKET=
S3_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
