# NEXUS v1.0 — MVP demonstration apparatus
# Collects from public cybersecurity news feeds, extracts entities, and stores results.
# Format: YAML with NEXUS schema

apparatus_name: "mvp-demo"
version: 1.0
description: "MVP pipeline: feed ingestion → sentiment + entity extraction → storage"
trust_level: restricted
owner: "probable-intel-ops"

nodes:
  - type: FeedNode
    id: "feed.krebs-security"
    targets:
      - feed: "https://krebsonsecurity.com/feed/"
      - feed: "https://feeds.feedburner.com/TheHackersNews"
    schedule:
      interval: "30m"
      jitter: 120
    filters:
      keywords: ["breach", "vulnerability", "ransomware", "zero-day", "exploit", "CVE", "hack"]
      min_word_count: 50
    emit:
      channel: "raw.feed.security"
      priority: high

  - type: SentimentNode
    id: "analyst.sentiment.security"
    subscribe:
      channels: ["raw.feed.security", "raw.recon.security"]
    backend:
      primary: "vader"
      fallback: "llm"
      llm_threshold: "0.4"
    emit:
      channel: "analysis.sentiment.security"
      priority: normal

  - type: EntityExtractorNode
    id: "analyst.entities.security"
    subscribe:
      channels: ["raw.feed.security"]
    emit:
      channel: "analysis.entities.security"
      priority: normal

  - type: ThreatAssessNode
    id: "analyst.threat.security"
    subscribe:
      channels: ["analysis.sentiment.security"]
    rules:
      - condition: "sentiment_score < -0.5"
        severity: HIGH
        label: "negative-security-signal"
      - condition: "sentiment_score < -0.7"
        severity: CRITICAL
        label: "critical-threat-indicator"
    emit:
      channel: "threat.security"
      priority: high

  - type: AnomalyNode
    id: "anomaly.security-signals"
    subscribe:
      channels: ["analysis.sentiment.security", "raw.feed.security"]
    config:
      window_seconds: 300
      sentiment_window_size: 100
      min_samples: 10
    rules:
      - condition: "sentiment_z_score < -2.5"
        severity: HIGH
        label: "sentiment-negativity-spike"
      - condition: "volume_z_score > 3.0"
        severity: HIGH
        label: "packet-volume-spike"
      - condition: "sentiment_volatility > 0.4"
        severity: MEDIUM
        label: "sentiment-volatility-spike"
    emit:
      channel: "analysis.anomaly"
      priority: high

  - type: KnowledgeGraphNode
    id: "kg.entities.security"
    subscribe:
      channels: ["analysis.entities.security"]
    config:
      persist_path: "/tmp/probable-intel-demo-kg.json"
      emit_interval_seconds: 300
      min_edge_weight: 2
      max_nodes: 5000
    emit:
      channel: "analysis.kg.summary"
      priority: low

  - type: ReconNode
    id: "recon.entities.security"
    subscribe:
      channels: ["analysis.kg.summary"]
    config:
      min_entity_degree: 2
      max_entities_per_run: 3
      cooldown_hours: 6
    emit:
      channel: "raw.recon.security"
      priority: normal

  - type: AlertNode
    id: "sentinel.alert.security"
    subscribe:
      channels: ["threat.security", "analysis.anomaly", "ci.deception.triggers", "ci.opsec.events"]
    emit:
      channel: "sink.alerts"
      priority: critical

  - type: StorageNode
    id: "archivist.storage.main"
    subscribe:
      channels:
        - "analysis.entities.security"
        - "analysis.sentiment.security"
        - "analysis.kg.summary"
        - "analysis.narrative.security"
        - "threat.security"
        - "ci.attribution.events"
    emit:
      channel: "sink.storage"
      priority: low

  - type: OpSecNode
    id: "ci.opsec.main"
    emit:
      channel: "ci.opsec.events"
      priority: normal

  - type: DeceptionNode
    id: "ci.deception.main"
    honeypots:
      - type: "fake_api_endpoint"
        path: "/api/v1/internal/nodes"
        canary_id: "honeypot-api-01"
      - type: "fake_dashboard"
        path: "/admin/status"
        canary_id: "honeypot-dash-01"
    emit:
      channel: "ci.deception.triggers"
      priority: critical

  - type: AttributionNode
    id: "ci.attribution.main"
    subscribe:
      channels: ["ci.deception.triggers"]
    config:
      session_window_seconds: 3600
      min_hits_to_profile: 2
      kg_node_id: "kg.entities.security"
    emit:
      channel: "ci.attribution.events"
      priority: high

  - type: TaskRouterNode
    id: "coordinator.task-router"
    subscribe:
      channels: ["threat.security", "analysis.anomaly", "ci.attribution.events"]
    config:
      min_severity: "HIGH"
      directive_cooldown_seconds: 300
      max_directives_per_hour: 10
    emit:
      channel: "system.task.directives"
      priority: high

  - type: NarrativeNode
    id: "analyst.narrative.security"
    subscribe:
      channels: ["analysis.sentiment.security", "analysis.entities.security"]
    config:
      narrative_window: 10
      emit_interval_seconds: 600
    llm:
      provider: "anthropic"
      model: "claude-haiku-4-5-20251001"
      api_key_env: "ANTHROPIC_API_KEY"
      budget_per_day_usd: 1.0
    emit:
      channel: "analysis.narrative.security"
      priority: low

storage:
  primary:
    backend: "sqlite"
    path: "/tmp/probable-intel-demo.db"
